# =========================================================================
#  Absensi Dapur MBG — Environment Variables
# =========================================================================

# Koneksi PostgreSQL.
# Lokal (contoh):   postgres://absensi:absensi@127.0.0.1:5432/absensi_dapur
# Vercel Postgres / Neon / Supabase: gunakan "Connection string" (pooled).
DATABASE_URL="postgres://user:password@host:5432/database?sslmode=require"

# Rahasia untuk menandatangani sesi (JWT). WAJIB diisi di produksi.
# Buat nilai acak: `openssl rand -hex 32`
AUTH_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"

# (Opsional) Kredensial admin awal yang dibuat saat database pertama kali diinisialisasi.
# Jika tidak diisi, default: admin / admin123 (WAJIB diganti setelah login pertama).
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAMA="Administrator Dapur"
