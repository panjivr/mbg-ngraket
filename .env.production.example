# --- YOUR DOMAIN (REQUIRED) ---
DOMAIN=example.com
ACME_EMAIL=vatorrohmanpanji@gmail.com

# --- SHARED SECRETS (already generated — do not reuse the old committed value) ---
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS
MBG_INTERNAL_SKIP_AUTH=REPLACE_WITH_DIFFERENT_64_HEX_CHARS

# Matikan langganan/billing: 1 = absensi+distribusi+tools langsung kepakai (Ngraket).
MBG_DISABLE_SUBSCRIPTION=1

# --- POSTGRES (backend Rust) ---
POSTGRES_USER=mbg
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=mbg_kitchen

# --- LOG LEVEL ---
RUST_LOG=info
